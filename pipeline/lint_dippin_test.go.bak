// ABOUTME: Tests for Dippin semantic lint rules (DIP101-DIP112).
// ABOUTME: Each rule has positive (warning) and negative (no warning) test cases.
package pipeline

import (
	"strings"
	"testing"
)

func TestLintDIP110_EmptyPrompt(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{
		ID:      "Agent1",
		Handler: "codergen",
		Attrs:   map[string]string{}, // No prompt
	})

	warnings := LintDippinRules(g)
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP110") && strings.Contains(w, "Agent1") {
			found = true
			break
		}
	}
	if !found {
		t.Error("expected DIP110 warning for empty prompt")
	}
}

func TestLintDIP110_NoWarningWithPrompt(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{
		ID:      "Agent1",
		Handler: "codergen",
		Attrs:   map[string]string{"prompt": "do something"},
	})

	warnings := LintDippinRules(g)
	for _, w := range warnings {
		if strings.Contains(w, "DIP110") {
			t.Errorf("unexpected DIP110 warning: %s", w)
		}
	}
}

