func TestLintDIP105_NoSuccessPath(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Start", Handler: "start"})
	g.AddNode(&Node{ID: "A", Handler: "codergen", Attrs: map[string]string{"prompt": "a"}})
	g.AddNode(&Node{ID: "Exit", Handler: "exit"})

	g.AddEdge(&Edge{From: "Start", To: "A"})
	// Only conditional edge to exit
	g.AddEdge(&Edge{From: "A", To: "Exit", Condition: "ctx.x = y"})

	warnings := lintDIP105(g)
	if len(warnings) == 0 {
		t.Error("expected DIP105 warning for no guaranteed success path")
	}
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP105") {
			found = true
			break
		}
	}
	if !found {
		t.Errorf("expected DIP105 warning, got: %v", warnings)
	}
}

