func TestLintDIP112_ReadsNotProduced(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Start", Handler: "start"})
	g.AddNode(&Node{
		ID:      "A",
		Handler: "codergen",
		Attrs: map[string]string{
			"prompt": "a",
			"reads":  "plan", // No upstream node produces "plan"
		},
	})

	g.AddEdge(&Edge{From: "Start", To: "A"})

	warnings := lintDIP112(g)
	if len(warnings) == 0 {
		t.Error("expected DIP112 warning for reads not produced upstream")
	}
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP112") && strings.Contains(w, "plan") {
			found = true
			break
		}
	}
	if !found {
		t.Errorf("expected DIP112 warning for plan, got: %v", warnings)
	}
}

