func TestLintDIP101_UnreachableViaConditional(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Start", Handler: "start"})
	g.AddNode(&Node{ID: "A", Handler: "codergen", Attrs: map[string]string{"prompt": "a"}})
	g.AddNode(&Node{ID: "B", Handler: "codergen", Attrs: map[string]string{"prompt": "b"}})

	g.AddEdge(&Edge{From: "Start", To: "A"}) // Unconditional
	g.AddEdge(&Edge{From: "A", To: "B", Condition: "ctx.x = y"}) // Conditional only

	warnings := lintDIP101(g)
	if len(warnings) == 0 {
		t.Error("expected DIP101 warning for node only reachable via conditional")
	}
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP101") && strings.Contains(w, "B") {
			found = true
			break
		}
	}
	if !found {
		t.Errorf("expected DIP101 warning for B, got: %v", warnings)
	}
}

func TestLintDIP101_NoWarningForUnconditionalPath(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Start", Handler: "start"})
	g.AddNode(&Node{ID: "A", Handler: "codergen", Attrs: map[string]string{"prompt": "a"}})
	g.AddNode(&Node{ID: "B", Handler: "codergen", Attrs: map[string]string{"prompt": "b"}})

	g.AddEdge(&Edge{From: "Start", To: "A"})
	g.AddEdge(&Edge{From: "A", To: "B"}) // Unconditional path to B

	warnings := lintDIP101(g)
	for _, w := range warnings {
		if strings.Contains(w, "DIP101") {
			t.Errorf("unexpected DIP101 warning: %s", w)
		}
	}
}

