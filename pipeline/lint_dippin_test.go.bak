func TestLintDIP103_OverlappingConditions(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Check", Handler: "codergen", Attrs: map[string]string{"prompt": "check"}})
	g.AddNode(&Node{ID: "A", Handler: "codergen", Attrs: map[string]string{"prompt": "a"}})
	g.AddNode(&Node{ID: "B", Handler: "codergen", Attrs: map[string]string{"prompt": "b"}})

	// Duplicate conditions
	g.AddEdge(&Edge{From: "Check", To: "A", Condition: "ctx.x = y"})
	g.AddEdge(&Edge{From: "Check", To: "B", Condition: "ctx.x = y"})

	warnings := lintDIP103(g)
	if len(warnings) == 0 {
		t.Error("expected DIP103 warning for overlapping conditions")
	}
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP103") && strings.Contains(w, "Check") {
			found = true
			break
		}
	}
	if !found {
		t.Errorf("expected DIP103 warning for Check, got: %v", warnings)
	}
}

func TestLintDIP103_NoWarningForDifferentConditions(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{ID: "Check", Handler: "codergen", Attrs: map[string]string{"prompt": "check"}})
	g.AddNode(&Node{ID: "A", Handler: "codergen", Attrs: map[string]string{"prompt": "a"}})
	g.AddNode(&Node{ID: "B", Handler: "codergen", Attrs: map[string]string{"prompt": "b"}})

	g.AddEdge(&Edge{From: "Check", To: "A", Condition: "ctx.x = y"})
	g.AddEdge(&Edge{From: "Check", To: "B", Condition: "ctx.x = z"})

	warnings := lintDIP103(g)
	for _, w := range warnings {
		if strings.Contains(w, "DIP103") {
			t.Errorf("unexpected DIP103 warning: %s", w)
		}
	}
}

func TestLintDIP109_NamespaceCollision(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{
		ID:      "A",
		Handler: "codergen",
		Attrs: map[string]string{
			"prompt": "a",
			"writes": "model",
		},
	})
	g.AddNode(&Node{
		ID:      "Sub",
		Handler: "subgraph",
		Attrs: map[string]string{
			"params": "model=gpt-4", // Shadows context key "model"
		},
	})

	warnings := lintDIP109(g)
	if len(warnings) == 0 {
		t.Error("expected DIP109 warning for namespace collision")
	}
	found := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP109") && strings.Contains(w, "model") {
			found = true
			break
		}
	}
	if !found {
		t.Errorf("expected DIP109 warning for model, got: %v", warnings)
	}
}

func TestLintDIP109_NoWarningForNonCollidingParams(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{
		ID:      "A",
		Handler: "codergen",
		Attrs: map[string]string{
			"prompt": "a",
			"writes": "summary",
		},
	})
	g.AddNode(&Node{
		ID:      "Sub",
		Handler: "subgraph",
		Attrs: map[string]string{
			"params": "model=gpt-4", // Doesn't shadow anything
		},
	})

	warnings := lintDIP109(g)
	for _, w := range warnings {
		if strings.Contains(w, "DIP109") {
			t.Errorf("unexpected DIP109 warning: %s", w)
		}
	}
}

func TestLintDippinRules_EmptyGraph(t *testing.T) {
	g := NewGraph("test")
	warnings := LintDippinRules(g)
	if len(warnings) != 0 {
		t.Errorf("expected no warnings for empty graph, got %d", len(warnings))
	}
}

func TestLintDippinRules_MultipleWarnings(t *testing.T) {
	g := NewGraph("test")
	g.AddNode(&Node{
		ID:      "Agent1",
		Handler: "codergen",
		Attrs:   map[string]string{}, // Empty prompt -> DIP110
	})
	g.AddNode(&Node{
		ID:      "Tool1",
		Handler: "tool",
		Attrs:   map[string]string{"tool_command": "ls"}, // No timeout -> DIP111
	})

	warnings := LintDippinRules(g)
	if len(warnings) < 2 {
		t.Errorf("expected at least 2 warnings, got %d: %v", len(warnings), warnings)
	}

	hasDIP110 := false
	hasDIP111 := false
	for _, w := range warnings {
		if strings.Contains(w, "DIP110") {
			hasDIP110 = true
		}
		if strings.Contains(w, "DIP111") {
			hasDIP111 = true
		}
	}

	if !hasDIP110 {
		t.Error("expected DIP110 warning")
	}
	if !hasDIP111 {
		t.Error("expected DIP111 warning")
	}
}
