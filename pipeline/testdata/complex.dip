workflow test_complex
  start: init
  exit: done

  defaults
    model: gpt-5.2
    provider: openai
    retry_policy: standard
    max_retries: 3
    fidelity: truncate

  agent init
    label: "Initialize"
    prompt: "Start the workflow"
    model: claude-sonnet-4-6
    provider: anthropic

  agent process
    label: "Process Data"
    prompt: "Process the input"
    system_prompt: "You are a data processor"
    max_turns: 5
    reasoning_effort: high
    fidelity: full
    auto_status: true

  tool verify
    label: "Verify Results"
    command: "echo pass"
    timeout: 30s
    retry_policy: aggressive
    max_retries: 5
    retry_target: process

  human approve
    label: "Approve?"
    mode: choice
    default: approved

  agent done
    label: "Complete"

  edges
    init -> process
    process -> verify  label: success
    verify -> approve  label: verified
    approve -> done  label: approved
    approve -> init  label: retry  restart: true
