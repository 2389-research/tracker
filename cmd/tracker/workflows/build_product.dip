workflow BuildProduct
  goal: "Read a SPEC.md, decompose into milestones, implement each with verification loops, cross-review the complete result, and verify full spec compliance."
  start: Start
  exit: Done

  defaults
    max_retries: 3
    max_restarts: 50
    fidelity: full
    model: claude-sonnet-4-6
    provider: anthropic

  agent Start
    label: Start
    prompt: Initialize pipeline.

  agent Done
    label: Done
    prompt: Pipeline complete.

  # ─── Phase 1: Read & Plan ──────────────────────────────────

  tool Setup
    label: "Setup Build Workspace"
    timeout: 10s
    command:
      set -eu
      mkdir -p .ai/build .ai/decisions .ai/milestones
      echo '.ai/' >> .gitignore 2>/dev/null || true
      sort -u .gitignore -o .gitignore
      if [ ! -f SPEC.md ]; then
        echo "ERROR: SPEC.md not found in repo root"
        exit 1
      fi
      wc -l SPEC.md | awk '{print $1" lines"}'
      printf 'setup-ready'

  agent ReadSpec
    label: "Read & Analyze Spec"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      Read SPEC.md thoroughly. Understand:
      - What is being built (the product)
      - What exists already (what to keep, what to throw away)
      - What the technical constraints are
      - What the success criteria are

      Produce a structured analysis to .ai/decisions/spec-analysis.md:
      ## Product summary (2-3 sentences)
      ## What exists and should be kept
      ## What must be replaced or removed
      ## Key technical decisions prescribed by the spec
      ## Implicit requirements (things the spec assumes but doesn't state)
      ## Risks and ambiguities

  agent Decompose
    label: "Decompose into Milestones"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      Based on the spec analysis, decompose the work into ordered milestones.

      Rules for decomposition:
      - Each milestone is independently verifiable (you can test it alone)
      - Milestones are ordered by dependency (foundations first)
      - Each milestone has a clear "done" definition
      - Prefer small milestones (1-3 files changed) over large ones
      - Destructive work (removing old code) is its own milestone, BEFORE building replacements
      - Total milestones should be 4-8 for a medium spec, 8-15 for a large one

      Write to .ai/decisions/milestones.md:
      ## Milestone N: [title]
      **Depends on**: [previous milestone numbers, or "none"]
      **Files**: [exact files to create/modify/delete]
      **Done when**: [specific, testable criteria]
      **Verify command**: [shell command that proves this milestone works, or "manual review"]

      Also write a one-line summary of each milestone — this becomes the build plan
      the user approves.

      If the spec or codebase has tests that are expected to fail until a later
      milestone wires things up, write those test names (one per line) to
      .ai/milestones/known_failures. The test runner will skip these. Remove
      test names from this file in the milestone where they should start passing.

  human ApprovePlan
    label: "Review the milestone plan. Approve, adjust, or reject."
    mode: freeform
    default: approve

  # ─── Phase 2: Build Loop ───────────────────────────────────
  #
  # The engine processes milestones sequentially. The Implement agent
  # reads .ai/milestones/current.md to know what to build next.
  # After each milestone, Verify checks it. On success, Advance moves
  # to the next milestone. On failure, the fix loop retries.
  #
  # When all milestones are done, Advance routes to cross-review.

  tool PickNextMilestone
    label: "Pick Next Milestone"
    timeout: 10s
    command:
      set -eu
      PLAN=".ai/decisions/milestones.md"
      DONE_DIR=".ai/milestones/done"
      mkdir -p "$DONE_DIR"

      # Count completed milestones
      DONE_COUNT=$(ls "$DONE_DIR" 2>/dev/null | wc -l | tr -d ' ')

      # Extract total milestone count (## Milestone N headers)
      TOTAL=$(grep -c '^## Milestone' "$PLAN" || echo 0)

      if [ "$DONE_COUNT" -ge "$TOTAL" ]; then
        echo "ALL_MILESTONES_COMPLETE"
        printf 'all-done'
        exit 0
      fi

      NEXT=$((DONE_COUNT + 1))
      echo "milestone $NEXT of $TOTAL"

      # Extract this milestone's section from the plan
      awk "/^## Milestone $NEXT/,/^## Milestone $((NEXT+1))/" "$PLAN" | \
        sed '/^## Milestone '"$((NEXT+1))"'/d' > .ai/milestones/current.md

      printf "milestone-$NEXT"

  agent Implement
    label: "Implement Current Milestone"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    max_turns: 50
    prompt:
      Read the current milestone spec at .ai/milestones/current.md.
      Read the full spec at SPEC.md for context.

      RULES:
      - Implement EXACTLY what this milestone requires. Nothing more.
      - Only touch the files listed in the milestone spec.
      - Follow the codebase's existing patterns and conventions.
      - Do NOT create documentation files unless the milestone requires them.
      - Do NOT refactor code outside the milestone's scope.
      - Run the verify command from the milestone if one is specified.
      - Commit your work with a conventional commit message referencing the milestone.

  tool TestMilestone
    label: "Test Current Milestone"
    timeout: 300s
    command:
      set -eu

      ATTEMPT_FILE=".ai/milestones/fix_attempts"
      ATTEMPTS=0
      if [ -f "$ATTEMPT_FILE" ]; then
        ATTEMPTS=$(cat "$ATTEMPT_FILE")
      fi
      ATTEMPTS=$((ATTEMPTS + 1))
      echo "$ATTEMPTS" > "$ATTEMPT_FILE"

      # Run tests FIRST — if they pass, the milestone is done regardless
      # of how many fix attempts we've burned.
      TEST_EXIT=0

      # Run the project's test suite.
      SKIP_PATTERN=""
      if [ -f .ai/milestones/known_failures ]; then
        SKIP_PATTERN=$(paste -sd'|' .ai/milestones/known_failures)
      fi

      if [ -f go.mod ]; then
        go build ./... 2>&1
        if [ -n "$SKIP_PATTERN" ]; then
          echo "--- skipping known failures: $SKIP_PATTERN ---"
          go test ./... 2>&1 | grep -v -E "$SKIP_PATTERN" || true
          go test ./... -run "^(?!($SKIP_PATTERN))" 2>&1 || TEST_EXIT=$?
        else
          go test ./... 2>&1 || TEST_EXIT=$?
        fi
      elif [ -f package.json ]; then
        npm test 2>&1 || TEST_EXIT=$?
      elif [ -f pyproject.toml ]; then
        uv run pytest 2>&1 || TEST_EXIT=$?
      elif [ -f Cargo.toml ]; then
        cargo test 2>&1 || TEST_EXIT=$?
      else
        echo "no known build system — skipping tests"
      fi

      # Run milestone-specific verify command if present
      if [ "$TEST_EXIT" -eq 0 ]; then
        VERIFY_CMD=$(grep 'Verify command' .ai/milestones/current.md | sed 's/.*: //' || true)
        if [ -n "$VERIFY_CMD" ] && [ "$VERIFY_CMD" != "manual review" ]; then
          echo "--- milestone verify ---"
          eval "$VERIFY_CMD" 2>&1 || TEST_EXIT=$?
        fi
      fi

      # Tests passed — reset counter and succeed
      if [ "$TEST_EXIT" -eq 0 ]; then
        echo "0" > "$ATTEMPT_FILE"
        printf 'tests-pass'
        exit 0
      fi

      # Tests failed — check if we've exhausted fix attempts
      echo "--- attempt $ATTEMPTS of 3 ---"
      if [ "$ATTEMPTS" -gt 3 ]; then
        echo "ESCALATE: milestone failed after $ATTEMPTS attempts"
        printf 'escalate'
        exit 1
      fi

      # Normal failure — let the fix loop handle it
      exit 1

  agent VerifyMilestone
    label: "Verify Milestone Completion"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    auto_status: true
    prompt:
      Read the current milestone spec at .ai/milestones/current.md.
      Check test results from ${ctx.tool_stdout}.

      Verify:
      1. Every "done when" criterion in the milestone is satisfied
      2. Only the files listed in the milestone were modified (check git diff)
      3. Tests pass
      4. No unnecessary changes, docs, or refactoring outside scope

      If all criteria met: STATUS:success
      If something is missing or wrong, describe exactly what and: STATUS:fail

  tool MarkMilestoneDone
    label: "Mark Milestone Complete"
    timeout: 5s
    command:
      set -eu
      DONE_DIR=".ai/milestones/done"
      mkdir -p "$DONE_DIR"
      DONE_COUNT=$(ls "$DONE_DIR" 2>/dev/null | wc -l | tr -d ' ')
      NEXT=$((DONE_COUNT + 1))
      cp .ai/milestones/current.md "$DONE_DIR/milestone-$NEXT.md"
      # Reset fix attempt counter for next milestone
      rm -f .ai/milestones/fix_attempts
      rm .ai/milestones/current.md
      printf "milestone-$NEXT-complete"

  agent FixMilestone
    label: "Fix Milestone Issues"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    max_turns: 50
    retry_target: TestMilestone
    max_retries: 5
    fallback_target: EscalateMilestone
    prompt:
      The current milestone failed verification. Read:
      - The milestone spec: .ai/milestones/current.md
      - The test output showing failures (in context from the previous node)
      - The relevant source files causing the failures

      This is a FULL implementation session, not a quick patch. You have the
      tools and time to properly investigate root causes, understand the domain
      logic, read the test expectations, and make correct fixes.

      Steps:
      1. Read the failing test file to understand what it expects
      2. Read the source code being tested to understand the current behavior
      3. Identify the root cause (not just the symptom)
      4. Implement the correct fix
      5. Run the specific failing test to verify before committing
      6. Commit the fix with a message like "fix(milestone-N): [what was fixed]"

      Do NOT make superficial patches. If a test expects story events to NOT
      merge, understand WHY they're merging and fix the decision logic.

  # ─── Phase 3: Cross-Review ─────────────────────────────────

  parallel ReviewParallel -> ReviewClaude, ReviewCodex, ReviewGemini

  agent ReviewClaude
    label: "Claude Review"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      Review the COMPLETE implementation against SPEC.md. All milestones are done.
      Check every requirement in the spec. Look for:
      - Missing requirements
      - Scope creep (things built that weren't in the spec)
      - Architectural violations (did the builder follow the spec's technical guidance?)
      - Leftover artifacts from removed code
      Write findings to .ai/build/review-claude.md with PASS/FAIL per spec section.

  agent ReviewCodex
    label: "Codex Review"
    model: gpt-5.4
    provider: openai
    reasoning_effort: high
    prompt:
      Review the COMPLETE implementation against SPEC.md. All milestones are done.
      Focus on:
      - Code quality and test coverage
      - Edge cases the spec calls out
      - Whether "throw away" items were actually removed
      - Regression risk
      Write findings to .ai/build/review-codex.md with PASS/FAIL per spec section.

  agent ReviewGemini
    label: "Gemini Review"
    model: gemini-2.5-pro
    provider: gemini
    reasoning_effort: high
    prompt:
      Review the COMPLETE implementation against SPEC.md. All milestones are done.
      Focus on:
      - Does the implementation match the spec's INTENT, not just its letter?
      - Are the "advice to the builder" sections respected?
      - Performance and scalability concerns
      - UX requirements met?
      Write findings to .ai/build/review-gemini.md with PASS/FAIL per spec section.

  fan_in ReviewJoin <- ReviewClaude, ReviewCodex, ReviewGemini

  agent SynthesizeReviews
    label: "Synthesize Reviews"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    auto_status: true
    prompt:
      Read all three reviews:
      - .ai/build/review-claude.md
      - .ai/build/review-codex.md
      - .ai/build/review-gemini.md

      Synthesize into .ai/decisions/review-synthesis.md:
      ## Consensus findings (all reviewers agree)
      ## Disputed findings (reviewers disagree — explain both sides)
      ## Required fixes (things that MUST change before shipping)
      ## Suggested improvements (nice-to-have, not blocking)

      If there are required fixes: STATUS:fail
      If all reviewers pass or only suggest improvements: STATUS:success

  agent ApplyReviewFixes
    label: "Apply Review Fixes"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    prompt:
      Read the review synthesis at .ai/decisions/review-synthesis.md.
      Apply ONLY the required fixes. Do NOT apply suggested improvements
      unless they are trivial (< 5 lines).

      Commit fixes with "fix: address cross-review findings"

  # ─── Phase 4: Final Verification ───────────────────────────

  tool FinalBuild
    label: "Final Build & Test"
    timeout: 300s
    command:
      set -eu
      if [ -f go.mod ]; then
        go build ./... 2>&1
        go test ./... 2>&1
      elif [ -f package.json ]; then
        npm test 2>&1
      elif [ -f pyproject.toml ]; then
        uv run pytest 2>&1
      elif [ -f Cargo.toml ]; then
        cargo test 2>&1
      fi
      printf 'final-build-pass'

  agent FinalSpecCheck
    label: "Final Spec Compliance"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    goal_gate: true
    fallback_target: EscalateReview
    auto_status: true
    prompt:
      This is the final gate. Read SPEC.md line by line.

      For EVERY requirement, prescription, and instruction in the spec:
      - Is it implemented?
      - Is it implemented correctly?
      - Was nothing extra added beyond what the spec asked for?

      Also verify:
      - No leftover files in .ai/build/ beyond review artifacts
      - No TODO/FIXME/HACK comments added
      - All "throw away" items from the spec were actually removed
      - Tests pass (check ${ctx.tool_stdout})

      Write the final compliance report to .ai/decisions/compliance.md

      If fully compliant: STATUS:success
      If not: STATUS:fail with specific list of gaps

  human EscalateMilestone
    label: "Milestone stuck — pick how to proceed"
    mode: freeform
    default: mark done
    prompt:
      The build loop hit a wall on the current milestone.
      The agent tried to fix it but couldn't get tests to pass.

      Options:
      - **mark done**: Override the test failure — you've verified the milestone is complete. Continues to the next milestone.
      - **retry**: Re-implement this milestone from scratch. Does NOT re-plan.
      - **accept**: Stop building milestones, skip to cleanup/commit.
      - **abandon**: Kill the pipeline immediately.

  human EscalateReview
    label: "Review flagged issues — pick how to proceed"
    mode: freeform
    default: accept
    prompt:
      Post-build review or verification flagged problems.

      Options:
      - **accept**: Ship as-is. The findings are acceptable or already addressed.
      - **retry**: Go back to Decompose and re-plan the build from scratch.
      - **abandon**: Kill the pipeline.

  tool Cleanup
    label: "Clean Build Artifacts"
    timeout: 10s
    command:
      set -eu
      # Keep decisions, remove build working files
      rm -rf .ai/build .ai/milestones
      # Keep: .ai/decisions/ (spec-analysis, milestones, review-synthesis, compliance)
      echo "Preserved decision log in .ai/decisions/"
      ls .ai/decisions/
      printf 'cleanup-done'

  agent FinalCommit
    label: "Final Commit"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: low
    prompt:
      Ensure all changes are committed. If there are uncommitted changes from
      the cleanup or final fixes, commit them. Include the commit hash.

  # ─── Edges ─────────────────────────────────────────────────

  edges
    Start -> Setup
    Setup -> ReadSpec
    ReadSpec -> Decompose  when ctx.outcome = success
    ReadSpec -> EscalateReview  when ctx.outcome = fail
    Decompose -> ApprovePlan  when ctx.outcome = success
    Decompose -> EscalateReview  when ctx.outcome = fail
    ApprovePlan -> PickNextMilestone  label: "approve"
    ApprovePlan -> Decompose  label: "adjust"  restart: true
    ApprovePlan -> Done  label: "reject"

    # Build loop: pick → implement → test → verify → mark done → pick next
    PickNextMilestone -> Implement  when ctx.tool_stdout not contains all-done
    PickNextMilestone -> ReviewParallel  when ctx.tool_stdout contains all-done
    PickNextMilestone -> EscalateMilestone
    Implement -> TestMilestone
    TestMilestone -> VerifyMilestone  when ctx.outcome = success
    TestMilestone -> EscalateMilestone  when ctx.tool_stdout contains escalate
    TestMilestone -> FixMilestone  when ctx.outcome = fail
    TestMilestone -> EscalateMilestone
    VerifyMilestone -> MarkMilestoneDone  when ctx.outcome = success
    VerifyMilestone -> FixMilestone  when ctx.outcome = fail
    VerifyMilestone -> EscalateMilestone
    MarkMilestoneDone -> PickNextMilestone  restart: true
    FixMilestone -> TestMilestone  restart: true

    # Milestone escalation — human decides per-milestone
    EscalateMilestone -> MarkMilestoneDone  label: "mark done"
    EscalateMilestone -> Implement  label: "retry"  restart: true
    EscalateMilestone -> Cleanup  label: "accept"
    EscalateMilestone -> Done  label: "abandon"

    # Cross-review
    ReviewClaude -> ReviewJoin
    ReviewCodex -> ReviewJoin
    ReviewGemini -> ReviewJoin
    ReviewJoin -> SynthesizeReviews
    SynthesizeReviews -> FinalBuild  when ctx.outcome = success
    SynthesizeReviews -> ApplyReviewFixes  when ctx.outcome = fail
    SynthesizeReviews -> EscalateReview
    ApplyReviewFixes -> FinalBuild

    # Final verification
    FinalBuild -> FinalSpecCheck  when ctx.outcome = success
    FinalBuild -> EscalateReview  when ctx.outcome = fail
    FinalBuild -> EscalateReview
    FinalSpecCheck -> Cleanup  when ctx.outcome = success
    FinalSpecCheck -> EscalateReview  when ctx.outcome = fail
    FinalSpecCheck -> EscalateReview

    # Review escalation — human decides for the whole build
    EscalateReview -> Cleanup  label: "accept"
    EscalateReview -> Decompose  label: "retry"  restart: true
    EscalateReview -> Done  label: "abandon"

    Cleanup -> FinalCommit
    FinalCommit -> Done
