workflow AskAndExecute
  goal: "Ask the user what to build, explore and spec it, fan out to 3 isolated implementations via git worktrees, cross-critique, select the best, apply it, and clean up everything else."
  start: Start
  exit: Done

  defaults
    max_retries: 2
    fidelity: summary:high
    model: claude-sonnet-4-6
    provider: anthropic

  agent Start
    label: Start
    prompt: Initialize pipeline.

  agent Done
    label: Done
    prompt: Pipeline complete.

  # ─── Phase 1: Understand ───────────────────────────────────

  tool SetupWorkspace
    label: "Setup Workspace"
    timeout: 10s
    command:
      set -eu
      mkdir -p .ai/worktrees .ai/candidates .ai/decisions
      echo '.ai/' >> .gitignore 2>/dev/null || true
      sort -u .gitignore -o .gitignore
      printf 'workspace-ready'

  human AskUser
    label: "What would you like done?"
    mode: freeform

  agent Explore
    label: "Explore Codebase"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    prompt:
      The user wants: ${ctx.human_response}

      Explore the codebase thoroughly. Understand the architecture, conventions,
      test patterns, and relevant files. Identify constraints, dependencies, and
      any existing code that relates to the request.

      Output a structured exploration summary:
      - **Relevant files**: paths and their roles
      - **Architecture constraints**: patterns that must be followed
      - **Test conventions**: how tests are structured and run
      - **Risks**: anything that could go wrong
      - **Build system**: how to build and test

  agent WriteSpec
    label: "Write Implementation Spec"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    prompt:
      Based on the exploration of the codebase, write a precise implementation
      specification for the user's request: ${ctx.human_response}

      The spec must be concrete enough that three independent agents can implement
      it without further clarification and produce comparable results.

      Structure:
      ## Objective
      One sentence.

      ## Scope
      Exactly which files to create/modify. Nothing else should be touched.

      ## Requirements
      Numbered list. Each requirement is testable.

      ## Non-requirements
      Explicitly list what is OUT of scope to prevent over-engineering.

      ## Success criteria
      How to verify the implementation is correct and complete.

      ## Constraints
      Architecture patterns, naming conventions, test patterns to follow.

      Write the spec to .ai/decisions/spec.md

  human ApproveSpec
    label: "Review the spec. Approve, refine, or reject."
    mode: freeform
    default: approve

  # ─── Phase 2: Isolated Implementation ──────────────────────

  tool SetupWorktrees
    label: "Create Git Worktrees"
    timeout: 30s
    command:
      set -eu
      MAIN_BRANCH=$(git rev-parse --abbrev-ref HEAD)
      for NAME in claude codex gemini; do
        BRANCH="impl/$NAME"
        WTDIR=".ai/worktrees/$NAME"
        git worktree remove --force "$WTDIR" 2>/dev/null || true
        git branch -D "$BRANCH" 2>/dev/null || true
        git worktree add "$WTDIR" -b "$BRANCH" HEAD
      done
      printf 'worktrees-ready'

  parallel ImplementParallel -> ImplementClaude, ImplementCodex, ImplementGemini

  agent ImplementClaude
    label: "Claude Implementation"
    model: claude-sonnet-4-6
    provider: anthropic
    working_dir: .ai/worktrees/claude
    reasoning_effort: high
    fidelity: full
    prompt:
      You are implementing a spec in an isolated git worktree. Read the spec
      from .ai/decisions/spec.md in the main repo (parent directory).

      RULES:
      - Implement EXACTLY what the spec says. Nothing more, nothing less.
      - Follow all constraints listed in the spec.
      - Run tests after implementation to verify.
      - Do NOT create documentation files unless the spec requires them.
      - Do NOT modify files outside the scope listed in the spec.

      When done, commit your work on this branch with a conventional commit message.

  agent ImplementCodex
    label: "Codex Implementation"
    model: gpt-5.4
    provider: openai
    working_dir: .ai/worktrees/codex
    reasoning_effort: high
    fidelity: full
    prompt:
      You are implementing a spec in an isolated git worktree. Read the spec
      from .ai/decisions/spec.md in the main repo (parent directory).

      RULES:
      - Implement EXACTLY what the spec says. Nothing more, nothing less.
      - Follow all constraints listed in the spec.
      - Run tests after implementation to verify.
      - Do NOT create documentation files unless the spec requires them.
      - Do NOT modify files outside the scope listed in the spec.

      When done, commit your work on this branch with a conventional commit message.

  agent ImplementGemini
    label: "Gemini Implementation"
    model: gemini-2.5-pro
    provider: gemini
    working_dir: .ai/worktrees/gemini
    reasoning_effort: high
    fidelity: full
    prompt:
      You are implementing a spec in an isolated git worktree. Read the spec
      from .ai/decisions/spec.md in the main repo (parent directory).

      RULES:
      - Implement EXACTLY what the spec says. Nothing more, nothing less.
      - Follow all constraints listed in the spec.
      - Run tests after implementation to verify.
      - Do NOT create documentation files unless the spec requires them.
      - Do NOT modify files outside the scope listed in the spec.

      When done, commit your work on this branch with a conventional commit message.

  fan_in ImplementJoin <- ImplementClaude, ImplementCodex, ImplementGemini

  # ─── Phase 3: Capture Evidence ─────────────────────────────

  tool CaptureAndTest
    label: "Capture Diffs & Run Tests"
    timeout: 300s
    command:
      set -eu
      MAIN=$(git rev-parse --abbrev-ref HEAD)
      RESULTS=""
      for NAME in claude codex gemini; do
        WTDIR=".ai/worktrees/$NAME"
        BRANCH="impl/$NAME"
        DIFF_FILE=".ai/candidates/$NAME.diff"
        TEST_FILE=".ai/candidates/$NAME.test"

        # Capture the diff against main
        git -C "$WTDIR" diff "$MAIN"..HEAD > "$DIFF_FILE" 2>/dev/null || true

        # Run tests in the worktree
        cd "$WTDIR"
        if [ -f go.mod ]; then
          go build ./... > "$OLDPWD/.ai/candidates/$NAME.test" 2>&1 && \
          go test ./... >> "$OLDPWD/.ai/candidates/$NAME.test" 2>&1
          TEST_EXIT=$?
        elif [ -f package.json ]; then
          npm test > "$OLDPWD/.ai/candidates/$NAME.test" 2>&1
          TEST_EXIT=$?
        else
          echo "no known build system" > "$OLDPWD/.ai/candidates/$NAME.test"
          TEST_EXIT=0
        fi
        cd "$OLDPWD"

        DIFF_LINES=$(wc -l < "$DIFF_FILE" | tr -d ' ')
        if [ $TEST_EXIT -eq 0 ]; then
          RESULTS="$RESULTS\n$NAME: TESTS PASS, diff=$DIFF_LINES lines"
        else
          RESULTS="$RESULTS\n$NAME: TESTS FAIL (exit=$TEST_EXIT), diff=$DIFF_LINES lines"
        fi
      done
      printf "$RESULTS"

  # ─── Phase 4: Cross-Critique ───────────────────────────────

  agent CrossCritique
    label: "Cross-Critique All Implementations"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    fidelity: full
    prompt:
      You are a senior engineer evaluating three independent implementations of the
      same spec. Read:
      - The spec: .ai/decisions/spec.md
      - Claude's diff: .ai/candidates/claude.diff
      - Claude's tests: .ai/candidates/claude.test
      - Codex's diff: .ai/candidates/codex.diff
      - Codex's tests: .ai/candidates/codex.test
      - Gemini's diff: .ai/candidates/gemini.diff
      - Gemini's tests: .ai/candidates/gemini.test

      For EACH implementation, evaluate:

      1. **Spec fidelity** (most important): Does it implement exactly what was
         specified? Nothing missing? Nothing extra? No scope creep? No unnecessary
         refactoring, documentation, or "improvements" beyond the spec?

      2. **Test evidence**: Do the tests pass? Did the implementation add appropriate
         tests? Are there test failures that indicate bugs?

      3. **Minimality**: Is the diff focused? Does it touch only the files the spec
         requires? Is the code clean without being over-engineered?

      Write a structured comparison to .ai/decisions/critique.md with:
      - Per-implementation assessment (strengths, weaknesses, spec deviations)
      - Head-to-head comparison table
      - Ranking: 1st, 2nd, 3rd with clear justification
      - Any disqualifications (test failures, spec violations, scope creep)

  # ─── Phase 5: Select & Apply ───────────────────────────────

  agent SelectWinner
    label: "Select Best Implementation"
    model: claude-opus-4-6
    provider: anthropic
    reasoning_effort: high
    auto_status: true
    prompt:
      Read the critique at .ai/decisions/critique.md.

      Select the winning implementation using this strict priority:
        1. SPEC FIDELITY — the implementation that most faithfully matches
           the spec wins. Anything extra is a penalty, not a bonus.
        2. TEST EVIDENCE — among spec-faithful implementations, prefer the
           one with the strongest passing test evidence.
        3. MINIMALITY — among tied implementations, prefer the smallest,
           cleanest diff.

      Write your decision to .ai/decisions/selection.md with:
      ## Winner
      Name of winning implementation (claude, codex, or gemini).

      ## Rationale
      Why this one won. Reference specific spec requirements.

      ## Runner-up
      Second place and what it did differently.

      ## Rejected
      For EACH non-winner: why it was not selected. Be specific — this is
      the record of why that approach was not taken.

      ## Spec compliance checklist
      For the winner only: check each numbered requirement from the spec.

      IMPORTANT: Output exactly one of these as the last line:
      STATUS:success

  tool ApplyWinner
    label: "Apply Winner & Clean Up"
    timeout: 60s
    command:
      set -eu
      MAIN=$(git rev-parse --abbrev-ref HEAD)

      # Extract winner name from selection.md
      WINNER=$(grep -A1 '## Winner' .ai/decisions/selection.md | tail -1 | tr -d ' \n' | tr '[:upper:]' '[:lower:]')

      # Validate
      if [ -z "$WINNER" ] || ! echo "claude codex gemini" | grep -qw "$WINNER"; then
        echo "ERROR: could not determine winner from .ai/decisions/selection.md"
        echo "Parsed: '$WINNER'"
        exit 1
      fi

      BRANCH="impl/$WINNER"

      # Merge the winning branch
      git merge "$BRANCH" --no-edit -m "feat: apply $WINNER implementation (selected by cross-critique)"

      # Remove all worktrees
      for NAME in claude codex gemini; do
        git worktree remove --force ".ai/worktrees/$NAME" 2>/dev/null || true
        git branch -D "impl/$NAME" 2>/dev/null || true
      done

      # Clean up candidate artifacts (keep decisions)
      rm -rf .ai/worktrees .ai/candidates

      printf "applied: $WINNER"

  # ─── Phase 6: Verify ───────────────────────────────────────

  tool FinalBuild
    label: "Final Build & Test"
    timeout: 300s
    command:
      set -eu
      if [ -f go.mod ]; then
        go build ./... 2>&1
        go test ./... 2>&1
      elif [ -f package.json ]; then
        npm test 2>&1
      fi
      # Verify no worktrees remain
      REMAINING=$(git worktree list --porcelain | grep -c 'worktree' || true)
      if [ "$REMAINING" -gt 1 ]; then
        echo "WARNING: leftover worktrees detected"
        git worktree list
        exit 1
      fi
      # Verify no impl branches remain
      if git branch | grep -q 'impl/'; then
        echo "WARNING: leftover impl branches"
        git branch | grep 'impl/'
        exit 1
      fi
      printf 'verified-clean'

  agent FinalVerify
    label: "Verify Spec Compliance"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: high
    goal_gate: true
    retry_target: ImplementClaude
    fallback_target: EscalateToHuman
    prompt:
      The winning implementation has been applied. Verify:

      1. Read the spec at .ai/decisions/spec.md
      2. Check every numbered requirement is satisfied
      3. Verify no files were modified outside the spec's scope
      4. Verify no documentation files were created unless required by spec
      5. Verify no leftover artifacts in .ai/candidates/ or .ai/worktrees/
      6. Confirm tests pass (check ${ctx.tool_stdout} from the build step)

      If everything checks out, output STATUS:success
      If something is wrong, describe what and output STATUS:fail
    auto_status: true

  human EscalateToHuman
    label: "Verification failed after retry. Please review."
    mode: freeform

  agent CommitFinal
    label: "Final Commit"
    model: claude-sonnet-4-6
    provider: anthropic
    reasoning_effort: low
    prompt:
      Ensure all changes are committed. The merge commit should already exist
      from ApplyWinner. If there are additional uncommitted changes from
      verification fixes, commit them with a conventional commit message.
      Include the commit hash in your output.

  # ─── Edges ─────────────────────────────────────────────────

  edges
    Start -> SetupWorkspace
    SetupWorkspace -> AskUser
    AskUser -> Explore
    Explore -> WriteSpec
    WriteSpec -> ApproveSpec
    ApproveSpec -> SetupWorktrees  label: "approve"
    ApproveSpec -> WriteSpec  label: "refine"  restart: true
    ApproveSpec -> Done  label: "reject"
    SetupWorktrees -> ImplementParallel
    ImplementClaude -> ImplementJoin
    ImplementCodex -> ImplementJoin
    ImplementGemini -> ImplementJoin
    ImplementJoin -> CaptureAndTest
    CaptureAndTest -> CrossCritique
    CrossCritique -> SelectWinner
    SelectWinner -> ApplyWinner
    ApplyWinner -> FinalBuild
    FinalBuild -> FinalVerify  when ctx.outcome = success
    FinalBuild -> EscalateToHuman  when ctx.outcome = fail
    FinalBuild -> EscalateToHuman
    FinalVerify -> CommitFinal  when ctx.outcome = success
    FinalVerify -> EscalateToHuman  when ctx.outcome = fail
    FinalVerify -> EscalateToHuman
    EscalateToHuman -> CommitFinal  label: "accept"
    EscalateToHuman -> Done  label: "abandon"
    CommitFinal -> Done
