    retry_target: CritiqueOpusOnGPT
    prompt:
      You are working in `run.working_dir`.

      Critique the GPT-5.4 review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  agent CritiqueOpusOnGemini
    label: "Opus Critiques Gemini Review"
    model: claude-sonnet-4-6
    provider: anthropic
    goal_gate: true
    retry_target: CritiqueOpusOnGemini
    prompt:
      You are working in `run.working_dir`.

      Critique the Gemini review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  agent CritiqueGPTOnOpus
    label: "GPT Critiques Opus Review"
    model: claude-sonnet-4-6
    provider: anthropic
    goal_gate: true
    retry_target: CritiqueGPTOnOpus
    prompt:
      You are working in `run.working_dir`.

      Critique the Opus review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  agent CritiqueGPTOnGemini
    label: "GPT Critiques Gemini Review"
    model: claude-sonnet-4-6
    provider: anthropic
    goal_gate: true
    retry_target: CritiqueGPTOnGemini
    prompt:
      You are working in `run.working_dir`.

      Critique the Gemini review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  agent CritiqueGeminiOnOpus
    label: "Gemini Critiques Opus Review"
    model: claude-sonnet-4-6
    provider: anthropic
    goal_gate: true
    retry_target: CritiqueGeminiOnOpus
    prompt:
      You are working in `run.working_dir`.

      Critique the Opus review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  agent CritiqueGeminiOnGPT
    label: "Gemini Critiques GPT Review"
    model: claude-sonnet-4-6
    provider: anthropic
    goal_gate: true
    retry_target: CritiqueGeminiOnGPT
    prompt:
      You are working in `run.working_dir`.

      Critique the GPT-5.4 review for missing checks, weak evidence, or mistaken conclusions. Are there issues they missed? Did they flag false positives? Be specific with file:line references.

  fan_in CritiquesJoin <- CritiqueOpusOnGPT, CritiqueOpusOnGemini, CritiqueGPTOnOpus, CritiqueGPTOnGemini, CritiqueGeminiOnOpus, CritiqueGeminiOnGPT

  agent ReviewConsensus
    label: "Review Consensus"
    goal_gate: true
    max_retries: 1
    retry_target: PickWinner
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Synthesize all reviews and cross-critiques into a single final verdict.

      ## Process
      1. Read all review outputs and critique outputs from context
      2. Identify issues confirmed by multiple reviewers (high confidence)
      3. Identify issues challenged by critiques (lower confidence — investigate)
      4. Categorize confirmed issues: Critical / Important / Suggestion
      5. For each Critical/Important issue, provide exact fix guidance

      ## Verdict Rules
      - **SUCCESS:** No Critical issues. No more than 2 Important issues (and they're minor). Ship it.
      - **RETRY:** Critical issues found OR 3+ Important issues. Route back to implementation for fixes.
      - **FAIL:** Fundamental architectural problems that can't be fixed incrementally. Route to auto-recovery.

      ## Output
      State your verdict clearly:
      outcome=success — ready to ship
      outcome=retry — needs fixes (list them)
      outcome=fail — blocked, route to auto-recovery

  tool CheckReworkBudget
    label: "Check Rework Budget"
    timeout: 60s
    command:
      #!/bin/sh
      set -eu
      mkdir -p .tracker
      COUNTER='.tracker/rework_count'
      count=0
      [ -f "$COUNTER" ] && count=$(cat "$COUNTER")
      count=$((count + 1))
      printf '%s' "$count" > "$COUNTER"
      if [ "$count" -gt 2 ]; then
        printf 'budget_exhausted'
      else
        printf 'budget_ok'
      fi

  agent FailureSummary
    label: "Failure Summary"
    model: claude-haiku-4-5
    provider: anthropic
    goal_gate: true
    retry_target: FailureSummary
    prompt:
      You are working in `run.working_dir`.

      Summarize why the pipeline failed, what remains unresolved, and concrete next steps for recovery. Write to docs/plans/failure-summary.md.

  tool VerifyTestsFinal
    label: "Final Test Verification"
    timeout: 120s
    command:
      set -eu
      echo '=== Final verification before ship ==='
      if [ -f pyproject.toml ]; then
        uv run pytest -v 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f package.json ]; then
        npm test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f go.mod ]; then
        go test ./... 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f Cargo.toml ]; then
        cargo test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      fi
      printf 'final-verification-pass'

  agent CreatePR
    label: "Create Pull Request"
    model: claude-haiku-4-5
    provider: anthropic
    goal_gate: true
    retry_target: CreatePR
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Finalize the project and push if possible.

      ## Process
      1. Ensure git repo exists:
         git rev-parse --git-dir >/dev/null 2>&1 || { git init && git add -A && git commit -m 'chore: initial commit'; }
      2. If no remote is configured (git remote | head -1 is empty):
         - Log: 'No remote configured — skipping PR creation'
         - Report: branch name, commit count, and working directory location
         - outcome=success (project is complete, just no remote to push to)
      3. If remote exists:
         a. git push -u origin HEAD
         b. Generate PR title (under 70 chars) and body from:
            - docs/plans/plan.md (what was planned)
            - git log --oneline (what was implemented)
            - Test results from context
         c. Create PR: gh pr create --title '<title>' --body '<summary + test plan>'
         d. Report the PR URL

  edges
    Start -> CheckExistingPlans
    CheckExistingPlans -> PickNextTask  when ctx.tool_stdout = resume  label: "resume — plan exists"  weight: 2
    CheckExistingPlans -> ArchiveOldPlans  when ctx.tool_stdout = fresh  label: "fresh start"
    CheckExistingPlans -> ArchiveOldPlans  label: fallback
    ArchiveOldPlans -> ExploreIdea
    ExploreIdea -> OmakaseFanOut
    OmakaseFanOut -> DesignExploreOpus
    OmakaseFanOut -> DesignExploreGPT
    OmakaseFanOut -> DesignExploreGemini
    DesignExploreOpus -> OmakaseJoin
    DesignExploreGPT -> OmakaseJoin
    DesignExploreGemini -> OmakaseJoin
    OmakaseJoin -> ConsolidateDesigns
    ConsolidateDesigns -> CommitBrief
    CommitBrief -> DraftPlan
    DraftPlan -> ValidatePlanFormat
    ValidatePlanFormat -> AuditPlanSpec  when ctx.tool_stdout = format_ok  label: "format ok"  weight: 2
    ValidatePlanFormat -> AutoRecover  when ctx.tool_stdout = fail_retries_exhausted  label: "plan loop exhausted"
    ValidatePlanFormat -> DraftPlan  when ctx.tool_stdout != format_ok and ctx.tool_stdout != fail_retries_exhausted  label: "format fail"  restart: true
    ValidatePlanFormat -> AutoRecover  label: fallback
    AuditPlanSpec -> CommitPlan  when ctx.outcome = success  label: "plan approved"  weight: 2
    AuditPlanSpec -> PatchPlan  when ctx.outcome = fail  label: "gaps found"
    AuditPlanSpec -> PatchPlan  label: fallback
    PatchPlan -> ValidatePlanFormat  restart: true
    CommitPlan -> SetupProject
    SetupProject -> VerifyBaseline
    VerifyBaseline -> PickNextTask
    PickNextTask -> CookoffFanOut  when ctx.tool_stdout != all_complete and ctx.tool_stdout != no_tasks_found  label: "has task"  weight: 2
    PickNextTask -> WriteScenarios  when ctx.tool_stdout = all_complete  label: "all done"
    PickNextTask -> AutoRecover  when ctx.tool_stdout = no_tasks_found  label: "no tasks in plan"
    PickNextTask -> AutoRecover  label: fallback
    CookoffFanOut -> ImplementTaskOpus
    CookoffFanOut -> ImplementTaskGPT
    CookoffFanOut -> ImplementTaskGemini
    ImplementTaskOpus -> CookoffJoin
    ImplementTaskGPT -> CookoffJoin
    ImplementTaskGemini -> CookoffJoin
    CookoffJoin -> PickWinner
    PickWinner -> SpecReview  when ctx.outcome = success  label: "winner picked"  weight: 2
    SpecReview -> QualityReview  when ctx.outcome = success  label: "spec pass"  weight: 2
    SpecReview -> CheckImplementBudget  when ctx.outcome = fail  label: "spec fail"
    SpecReview -> CheckImplementBudget  label: fallback
    QualityReview -> MarkTaskComplete  when ctx.outcome = success  label: "quality pass"  weight: 2
    QualityReview -> CheckImplementBudget  when ctx.outcome = fail  label: "quality fail"
    QualityReview -> MarkTaskComplete  label: fallback
    CheckImplementBudget -> CookoffFanOut  when ctx.tool_stdout = budget_ok  label: "retry ok"  weight: 2  restart: true
    CheckImplementBudget -> AutoRecover  when ctx.tool_stdout = budget_exhausted  label: "too many attempts"
    CheckImplementBudget -> AutoRecover  label: fallback
    MarkTaskComplete -> PickNextTask  restart: true
    PickWinner -> DebugInvestigate  when ctx.outcome = fail  label: "retries exhausted"
    PickWinner -> DebugInvestigate  label: fallback
    DebugInvestigate -> CookoffFanOut  when ctx.outcome = success  label: "fixed, re-verify"  weight: 2  restart: true
    DebugInvestigate -> ReplanTask  when ctx.outcome = fail  label: "can't fix"
    DebugInvestigate -> ReplanTask  label: fallback
    ReplanTask -> PickNextTask  when ctx.outcome = success  label: replanned  weight: 2  restart: true
    ReplanTask -> AutoRecover  when ctx.outcome = fail  label: stuck
    ReplanTask -> AutoRecover  label: fallback
    AutoRecover -> PickNextTask  when ctx.outcome = success  label: recovered  weight: 2  restart: true
    AutoRecover -> FailureSummary  when ctx.outcome = fail  label: unrecoverable
    AutoRecover -> FailureSummary  label: fallback
    WriteScenarios -> RunScenarios
    RunScenarios -> ExtractScenarioPatterns  when ctx.tool_stdout = scenarios_pass  label: "scenarios pass"  weight: 2
    RunScenarios -> FixScenarioFailures  when ctx.tool_stdout != scenarios_pass  label: "scenarios fail"
    RunScenarios -> FixScenarioFailures  label: fallback
    FixScenarioFailures -> RunScenarios  restart: true
    ExtractScenarioPatterns -> ValidateBuild
    ValidateBuild -> ReviewFanOut  when ctx.outcome = success  label: "build pass"  weight: 2
    ValidateBuild -> CheckReworkBudget  when ctx.outcome = fail  label: "build fail"
    ValidateBuild -> FailureSummary  label: fallback
    ReviewFanOut -> FinalReviewOpus
    ReviewFanOut -> FinalReviewGPT
    ReviewFanOut -> FinalReviewGemini
    FinalReviewOpus -> ReviewsJoin
    FinalReviewGPT -> ReviewsJoin
    FinalReviewGemini -> ReviewsJoin
    ReviewsJoin -> CritiqueFanOut
    CritiqueFanOut -> CritiqueOpusOnGPT
    CritiqueFanOut -> CritiqueOpusOnGemini
    CritiqueFanOut -> CritiqueGPTOnOpus
    CritiqueFanOut -> CritiqueGPTOnGemini
    CritiqueFanOut -> CritiqueGeminiOnOpus
    CritiqueFanOut -> CritiqueGeminiOnGPT
    CritiqueOpusOnGPT -> CritiquesJoin
    CritiqueOpusOnGemini -> CritiquesJoin
    CritiqueGPTOnOpus -> CritiquesJoin
    CritiqueGPTOnGemini -> CritiquesJoin
    CritiqueGeminiOnOpus -> CritiquesJoin
    CritiqueGeminiOnGPT -> CritiquesJoin
    CritiquesJoin -> ReviewConsensus
    ReviewConsensus -> VerifyTestsFinal  when ctx.outcome = success  label: pass  weight: 2
    ReviewConsensus -> CheckReworkBudget  when ctx.outcome = retry  label: rework
    ReviewConsensus -> FailureSummary  when ctx.outcome = fail  label: blocked
    ReviewConsensus -> VerifyTestsFinal  label: fallback
    CheckReworkBudget -> CookoffFanOut  when ctx.tool_stdout = budget_ok  label: "rework ok"  weight: 2  restart: true
    CheckReworkBudget -> FailureSummary  when ctx.tool_stdout = budget_exhausted  label: "rework budget exhausted"
    CheckReworkBudget -> FailureSummary  label: fallback
    FailureSummary -> Exit
    VerifyTestsFinal -> CreatePR  when ctx.outcome = success  label: "tests pass"  weight: 2
    VerifyTestsFinal -> CheckReworkBudget  when ctx.outcome = fail  label: "tests fail"
    VerifyTestsFinal -> FailureSummary  label: fallback
    CreatePR -> FailureSummary  when ctx.outcome = fail  label: "PR failed"
    CreatePR -> Exit  when ctx.outcome = success  label: shipped  weight: 2
    CreatePR -> Exit  label: fallback
