{
  "tests": [
    {
      "name": "happy path — approve spec, implement, review, ship",
      "scenario": {},
      "expect": {
        "status": "success",
        "visited": ["Start", "SetupWorkspace", "AskUser", "Explore", "WriteSpec", "ApproveSpec", "SetupWorktrees", "Done"]
      }
    },
    {
      "name": "spec rejected — reaches Done via reject edge",
      "scenario": {"ApproveSpec.preferred_label": "reject"},
      "expect": {
        "status": "success",
        "visited": ["ApproveSpec", "Done"]
      }
    },
    {
      "name": "build fails — escalate to human",
      "scenario": {"FinalBuild.outcome": "fail"},
      "expect": {
        "status": "success",
        "visited": ["FinalBuild", "EscalateToHuman"]
      }
    }
  ]
}
