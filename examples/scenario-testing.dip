  tool VerifyTestsFinal
    label: "Final Test Verification"
    timeout: 120s
    command:
      set -eu
      echo '=== Final verification before ship ==='
      if [ -f pyproject.toml ]; then
        uv run pytest -v 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f package.json ]; then
        npm test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f go.mod ]; then
        go test ./... 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      elif [ -f Cargo.toml ]; then
        cargo test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }
      fi
      printf 'final-verification-pass'

  agent CreatePR
    label: "Create Pull Request"
    model: claude-haiku-4-5
    provider: anthropic
    goal_gate: true
    retry_target: CreatePR
    max_retries: 3
    prompt:
      You are working in `run.working_dir`.

      ## Task
      Finalize the project and push if possible.

      ## Process
      1. Ensure git repo exists:
         git rev-parse --git-dir >/dev/null 2>&1 || { git init && git add -A && git commit -m 'chore: initial commit'; }
      2. If no remote is configured (git remote | head -1 is empty):
         - Log: 'No remote configured — skipping PR creation'
         - Report: branch name, commit count, and working directory location
         - outcome=success (project is complete, just no remote to push to)
      3. If remote exists:
         a. git push -u origin HEAD
         b. Generate PR title (under 70 chars) and body from:
            - docs/plans/plan.md (what was planned)
            - git log --oneline (what was implemented)
            - Test results from context
         c. Create PR: gh pr create --title '<title>' --body '<summary + test plan>'
         d. Report the PR URL

  edges
    Start -> CheckExistingPlans
    CheckExistingPlans -> PickNextTask  when ctx.tool_stdout = resume  label: "resume — plan exists"  weight: 2
    CheckExistingPlans -> ArchiveOldPlans  when ctx.tool_stdout = fresh  label: "fresh start"
    CheckExistingPlans -> ArchiveOldPlans  label: fallback
    ArchiveOldPlans -> ExploreIdea
    ExploreIdea -> HumanBrainstorm
    HumanBrainstorm -> RefineUnderstanding
    RefineUnderstanding -> CheckBrainstormDone
    CheckBrainstormDone -> HumanBrainstorm  when ctx.tool_stdout = more_questions  label: "more questions"  restart: true
    CheckBrainstormDone -> WriteDesignBrief  when ctx.tool_stdout = done  label: "ready for design"  weight: 2
    CheckBrainstormDone -> HumanBrainstorm  label: fallback  restart: true
    WriteDesignBrief -> ApproveDesign
    ApproveDesign -> CommitBrief  when ctx.outcome = success  label: "[Y] Approve"  weight: 2
    ApproveDesign -> DesignFeedback  when ctx.outcome = fail  label: "[N] Revise"
    ApproveDesign -> DesignFeedback  label: fallback
    DesignFeedback -> IncorporateDesignFeedback
    IncorporateDesignFeedback -> ApproveDesign  restart: true
    CommitBrief -> DraftPlan
    DraftPlan -> ValidatePlanFormat
    ValidatePlanFormat -> AuditPlanSpec  when ctx.tool_stdout = format_ok  label: "format ok"  weight: 2
    ValidatePlanFormat -> HumanHelp  when ctx.tool_stdout = fail_retries_exhausted  label: "plan loop exhausted"
    ValidatePlanFormat -> DraftPlan  when ctx.tool_stdout != format_ok and ctx.tool_stdout != fail_retries_exhausted  label: "format fail"  restart: true
    ValidatePlanFormat -> HumanHelp  label: fallback
    AuditPlanSpec -> CommitPlan  when ctx.outcome = success  label: "plan approved"  weight: 2
    AuditPlanSpec -> PatchPlan  when ctx.outcome = fail  label: "gaps found"
    AuditPlanSpec -> PatchPlan  label: fallback
    PatchPlan -> ValidatePlanFormat  restart: true
    CommitPlan -> SetupProject
    SetupProject -> VerifyBaseline
    VerifyBaseline -> PickNextTask
    PickNextTask -> ImplementTask  when ctx.tool_stdout != all_complete and ctx.tool_stdout != no_tasks_found  label: "has task"  weight: 2
    PickNextTask -> WriteScenarios  when ctx.tool_stdout = all_complete  label: "all done"
    PickNextTask -> HumanHelp  when ctx.tool_stdout = no_tasks_found  label: "no tasks in plan"
    PickNextTask -> HumanHelp  label: fallback
    ImplementTask -> CheckImplementerReady
    CheckImplementerReady -> SpecReview  when ctx.tool_stdout = ready  label: "ready to review"  weight: 2
    CheckImplementerReady -> ImplementerQuestion  when ctx.tool_stdout = has_question  label: "has question"
    CheckImplementerReady -> ImplementerQuestion  label: fallback
    ImplementerQuestion -> ImplementTask  restart: true
    SpecReview -> QualityReview  when ctx.outcome = success  label: "spec pass"  weight: 2
    SpecReview -> CheckImplementBudget  when ctx.outcome = fail  label: "spec fail"
    SpecReview -> CheckImplementBudget  label: fallback
    QualityReview -> MarkTaskComplete  when ctx.outcome = success  label: "quality pass"  weight: 2
    QualityReview -> CheckImplementBudget  when ctx.outcome = fail  label: "quality fail"
    QualityReview -> MarkTaskComplete  label: fallback
    CheckImplementBudget -> ImplementTask  when ctx.tool_stdout = budget_ok  label: "retry ok"  weight: 2  restart: true
    CheckImplementBudget -> HumanHelp  when ctx.tool_stdout = budget_exhausted  label: "too many attempts"
    CheckImplementBudget -> HumanHelp  label: fallback
    MarkTaskComplete -> PickNextTask  restart: true
    ImplementTask -> DebugInvestigate  when ctx.outcome = fail  label: "retries exhausted"
    DebugInvestigate -> ImplementTask  when ctx.outcome = success  label: "fixed, re-verify"  weight: 2  restart: true
    DebugInvestigate -> ReplanTask  when ctx.outcome = fail  label: "can't fix"
    DebugInvestigate -> ReplanTask  label: fallback
    ReplanTask -> PickNextTask  when ctx.outcome = success  label: replanned  weight: 2  restart: true
    ReplanTask -> HumanHelp  when ctx.outcome = fail  label: stuck
    ReplanTask -> HumanHelp  label: fallback
    HumanHelp -> ResumeAfterHelp
    ResumeAfterHelp -> PickNextTask  restart: true
    WriteScenarios -> RunScenarios
    RunScenarios -> ExtractScenarioPatterns  when ctx.tool_stdout = scenarios_pass  label: "all pass"  weight: 2
    RunScenarios -> FixScenarioFailures  when ctx.tool_stdout = scenarios_fail  label: failures
    RunScenarios -> FixScenarioFailures  label: fallback
    FixScenarioFailures -> RunScenarios  restart: true
    ExtractScenarioPatterns -> ValidateBuild
    ValidateBuild -> ReviewFanOut  when ctx.outcome = success  label: "build pass"  weight: 2
    ValidateBuild -> CheckReworkBudget  when ctx.outcome = fail  label: "build fail"
    ValidateBuild -> FailureSummary  label: fallback
    ReviewFanOut -> FinalReviewOpus
    ReviewFanOut -> FinalReviewGPT
    ReviewFanOut -> FinalReviewGemini
    FinalReviewOpus -> ReviewsJoin
    FinalReviewGPT -> ReviewsJoin
    FinalReviewGemini -> ReviewsJoin
    ReviewsJoin -> CritiqueFanOut
    CritiqueFanOut -> CritiqueOpusOnGPT
    CritiqueFanOut -> CritiqueOpusOnGemini
    CritiqueFanOut -> CritiqueGPTOnOpus
    CritiqueFanOut -> CritiqueGPTOnGemini
    CritiqueFanOut -> CritiqueGeminiOnOpus
    CritiqueFanOut -> CritiqueGeminiOnGPT
    CritiqueOpusOnGPT -> CritiquesJoin
    CritiqueOpusOnGemini -> CritiquesJoin
    CritiqueGPTOnOpus -> CritiquesJoin
    CritiqueGPTOnGemini -> CritiquesJoin
    CritiqueGeminiOnOpus -> CritiquesJoin
    CritiqueGeminiOnGPT -> CritiquesJoin
    CritiquesJoin -> ReviewConsensus
    ReviewConsensus -> VerifyTestsFinal  when ctx.outcome = success  label: pass  weight: 2
    ReviewConsensus -> CheckReworkBudget  when ctx.outcome = retry  label: rework
    ReviewConsensus -> FailureSummary  when ctx.outcome = fail  label: blocked
    ReviewConsensus -> VerifyTestsFinal  label: fallback
    CheckReworkBudget -> ImplementTask  when ctx.tool_stdout = budget_ok  label: "rework ok"  weight: 2
    CheckReworkBudget -> FailureSummary  when ctx.tool_stdout = budget_exhausted  label: "rework budget exhausted"
    CheckReworkBudget -> FailureSummary  label: fallback
    FailureSummary -> Exit
    VerifyTestsFinal -> CreatePR  when ctx.outcome = success  label: "tests pass"  weight: 2
    VerifyTestsFinal -> CheckReworkBudget  when ctx.outcome = fail  label: "tests fail"
    VerifyTestsFinal -> FailureSummary  label: fallback
    CreatePR -> FailureSummary  when ctx.outcome = fail  label: "PR failed"
    CreatePR -> Exit  when ctx.outcome = success  label: shipped  weight: 2
    CreatePR -> Exit  label: fallback
