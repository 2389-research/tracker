{
  "tests": [
    {
      "name": "happy path — all phases pass, review, ship",
      "scenario": {},
      "expect": {
        "status": "success",
        "visited": ["Start", "Setup", "AnalyzeSpec", "BuildPlan", "ApprovePlan", "SetupPhase1Worktrees", "Phase1Parallel", "Phase1Join", "MergePhase1", "GatePhase1", "Done"]
      }
    },
    {
      "name": "plan rejected — reaches Done",
      "scenario": {"ApprovePlan.preferred_label": "reject"},
      "expect": {
        "status": "success",
        "visited": ["ApprovePlan", "Done"]
      }
    },
    {
      "name": "phase 1 gate fails — fix loop fires",
      "scenario": {"GatePhase1.outcome": "fail"},
      "expect": {
        "visited": ["GatePhase1", "FixPhase1"]
      }
    },
    {
      "name": "merge conflict — escalate",
      "scenario": {"MergePhase1.outcome": "fail"},
      "expect": {
        "visited": ["MergePhase1", "EscalateToHuman"]
      }
    },
    {
      "name": "review finds blocking issues — fix and re-gate",
      "scenario": {"SynthesizeReviews.outcome": "fail"},
      "expect": {
        "visited": ["SynthesizeReviews", "ApplyReviewFixes", "FinalGates"]
      }
    },
    {
      "name": "final gates fail — escalate",
      "scenario": {"FinalGates.outcome": "fail"},
      "expect": {
        "visited": ["FinalGates", "EscalateToHuman"]
      }
    }
  ]
}
