digraph SemportThematic {
  graph [
    label="$target_name Thematic Semport (Agentic Loop)",
    goal="Port $source_ref into $target_name via evolving thematic checklist and iterative implementation/validation. The source is a Python/Flask surveillance platform. The target is idiomatic Go (module github.com/harperreed/glimpser-go). Do NOT mirror Python structure — use Go-native patterns (net/http, database/sql, goroutines, interfaces, error returns).",
    source_ref="/Users/harper/workspace/personal/glimpser",
    target_module=".",
    target_name="glimpser-go",
    rankdir=LR,
    default_max_retry=5,
    retry_target="Plan",
    fallback_retry_target="Start"
  ];

  Start [shape=Mdiamond, label="Start"];
  Exit [shape=Msquare, label="Exit"];

  EnsureWorkspace [
    shape=parallelogram,
    label="Ensure semport workspace files",
    tool_command="set -eu\nmkdir -p .ai/semport/$target_name\nif [ ! -f go.mod ]; then\n  go mod init github.com/harperreed/glimpser-go\n  mkdir -p cmd/glimpser internal .ai/semport/$target_name\nfi\nif [ ! -f .ai/semport/$target_name/thematic-spec.md ]; then\n  cat > .ai/semport/$target_name/thematic-spec.md <<'SPECEOF'\n# $target_name Thematic Semport Spec\n\n## Scope\n- Semantic port of $source_ref into $target_module.\n- Target: idiomatic Go (github.com/harperreed/glimpser-go)\n- Source: Python/Flask surveillance platform\n\n## Checklist\n<!-- planner maintains checklist here -->\n\n## Validation Feedback\n<!-- validator/appraiser writes concise latest loop feedback here -->\nSPECEOF\nfi\nif [ ! -f .ai/semport/$target_name/validation-feedback.md ]; then\n  cat > .ai/semport/$target_name/validation-feedback.md <<'FBEOF'\n# Validation Feedback\n- none yet\nFBEOF\nfi\nprintf 'workspace ready'"
  ];

  Plan [
    shape=box,
    label="Plan Thematic Checklist (Opus 4.6)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Use tools to inspect $source_ref and $target_module. Propose thematic sections and a concrete markdown checklist for semantic porting. Create a numbered artifact `.ai/semport/$target_name/plan-NNN.md` where NNN is next zero-padded index (scan existing plan-*.md, max+1, start 001). If .ai/semport/$target_name/thematic-spec.md already exists, UPDATE it in-place and preserve completed items; do not rewrite from scratch. Consume .ai/semport/$target_name/validation-feedback.md and fold its failures/gaps into checklist updates. Maintain one authoritative checklist with explicit [ ] and [x] items grouped by theme. Keep completed checks intact. Add a short 'Next implementation target' section naming exactly one checklist slice to implement next. Output concise rationale and what changed."
  ];

  ImplementSlice [
    shape=box,
    label="Implement Next Checklist Slice (GPT-5.4)",
    llm_provider="openai",
    llm_model="gpt-5.4",
    reasoning_effort="high",
    auto_status=true,
    allow_partial=true,
    prompt="Read .ai/semport/$target_name/thematic-spec.md and implement the highest-priority unchecked checklist slices in $target_module using semantic parity with $source_ref. Tackle as many related items as you can in one pass while keeping the build green. Discover needed files yourself via tools; do not expect preloaded file dumps. Make concrete code changes, then mark only truly completed checklist entries as [x]. Write a short implementation note section into .ai/semport/$target_name/thematic-spec.md describing what changed. Also write `.ai/semport/$target_name/implement-NNN.md` where NNN is next zero-padded index (scan implement-*.md, max+1, start 001) containing changed files, tests/build commands run, and any blockers."
  ];

  BuildGate [
    shape=parallelogram,
    label="Build gate (must pass)",
    tool_command="set -eu\ngo build ./... >/tmp/semport-thematic-$target_name-build.log 2>&1 || {\n  printf 'BUILD_FAIL\\n'\n  head -80 /tmp/semport-thematic-$target_name-build.log || true\n  exit 1\n}\ngo vet ./... >>/tmp/semport-thematic-$target_name-build.log 2>&1 || {\n  printf 'VET_FAIL\\n'\n  tail -40 /tmp/semport-thematic-$target_name-build.log || true\n  exit 1\n}\nprintf 'BUILD_PASS'"
  ];

  Validate [
    shape=box,
    label="Validate Implementation (Opus 4.6)",
    llm_provider="anthropic",
    llm_model="claude-opus-4-6",
    reasoning_effort="high",
    auto_status=true,
    prompt="Validate the latest implementation against .ai/semport/$target_name/thematic-spec.md and $source_ref by using tools. Report missing behavior, incomplete checklist claims, and concrete evidence commands/files. Write findings to numbered artifact `.ai/semport/$target_name/validation-NNN.md` where NNN is next zero-padded index (scan validation-*.md excluding validation-feedback.md, max+1, start 001). Update .ai/semport/$target_name/validation-feedback.md with precise failure reasons and what to fix next. Then update .ai/semport/$target_name/thematic-spec.md in-place: keep truthful [x], revert any invalid completion to [ ], and add/refine checklist items based on discovered gaps."
  ];

  CheckCompletion [
    shape=parallelogram,
    label="Check if checklist fully complete",
    tool_command="set -eu\nif rg -n '^- \\[ \\]' .ai/semport/$target_name/thematic-spec.md >/dev/null 2>&1; then\n  printf 'INCOMPLETE'\n  exit 1\nfi\nprintf 'COMPLETE'"
  ];

  Start -> EnsureWorkspace;
  EnsureWorkspace -> Plan;
  Plan -> ImplementSlice;
  ImplementSlice -> BuildGate;
  BuildGate -> Validate [condition="outcome=success", label="build_passed"];
  BuildGate -> Plan [condition="outcome=fail", label="build_failed_replan", loop_restart=true];
  Validate -> CheckCompletion;
  CheckCompletion -> Exit [condition="outcome=success", label="all_checked_and_validated"];
  CheckCompletion -> Plan [condition="outcome=fail", label="needs_more_porting", loop_restart=true];
}
