    goal_gate=true,
    retry_target="PickWinner",
    max_retries=1,
    prompt="You are working in `run.working_dir`.

## Task
Synthesize all reviews and cross-critiques into a single final verdict.

## Process
1. Read all review outputs and critique outputs from context
2. Identify issues confirmed by multiple reviewers (high confidence)
3. Identify issues challenged by critiques (lower confidence — investigate)
4. Categorize confirmed issues: Critical / Important / Suggestion
5. For each Critical/Important issue, provide exact fix guidance

## Verdict Rules
- **SUCCESS:** No Critical issues. No more than 2 Important issues (and they're minor). Ship it.
- **RETRY:** Critical issues found OR 3+ Important issues. Route back to implementation for fixes.
- **FAIL:** Fundamental architectural problems that can't be fixed incrementally. Needs human.

## Output
State your verdict clearly:
outcome=success — ready to ship
outcome=retry — needs fixes (list them)
outcome=fail — blocked, needs human intervention
"
  ];

  CheckReworkBudget [
    shape=parallelogram,
    label="Check Rework Budget",
    tool_command="#!/bin/sh\nset -eu\nmkdir -p .tracker\nCOUNTER='.tracker/rework_count'\ncount=0\n[ -f \"$COUNTER\" ] && count=$(cat \"$COUNTER\")\ncount=$((count + 1))\nprintf '%s' \"$count\" > \"$COUNTER\"\nif [ \"$count\" -gt 2 ]; then\n  printf 'budget_exhausted'\nelse\n  printf 'budget_ok'\nfi"
  ];

  FailureSummary [
    shape=box,
    label="Failure Summary",
    goal_gate=true,
    retry_target="FailureSummary",
    prompt="You are working in `run.working_dir`.

Summarize why the final review failed, what remains unresolved, and concrete next steps for recovery. Write to docs/plans/failure-summary.md."
  ];

  // ============================================================
  // PHASE 6 — FINISH  (superpowers:finishing-a-development-branch)
  // ============================================================

  VerifyTestsFinal [
    shape=parallelogram,
    label="Final Test Verification",
    tool_command="set -eu\necho '=== Final verification before ship ==='\nif [ -f pyproject.toml ]; then\n  uv run pytest -v 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }\nelif [ -f package.json ]; then\n  npm test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }\nelif [ -f go.mod ]; then\n  go test ./... 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }\nelif [ -f Cargo.toml ]; then\n  cargo test 2>&1 || { echo 'FINAL_TEST_FAIL'; exit 1; }\nfi\nprintf 'final-verification-pass'"
  ];

  CreatePR [
    shape=box,
    class="implement",
    label="Create Pull Request",
    goal_gate=true,
    retry_target="CreatePR",
    prompt="You are working in `run.working_dir`.

## Task
Finalize the project and push if possible.

## Process
1. Ensure git repo exists:
   git rev-parse --git-dir >/dev/null 2>&1 || { git init && git add -A && git commit -m 'chore: initial commit'; }
2. If no remote is configured (git remote | head -1 is empty):
   - Log: 'No remote configured — skipping PR creation'
   - Report: branch name, commit count, and working directory location
   - outcome=success (project is complete, just no remote to push to)
3. If remote exists:
   a. git push -u origin HEAD
   b. Generate PR title (under 70 chars) and body from:
      - docs/plans/plan.md (what was planned)
      - git log --oneline (what was implemented)
      - Test results from context
   c. Create PR: gh pr create --title '<title>' --body '<summary + test plan>'
   d. Report the PR URL
"
  ];

  // ============================================================
  // EDGES
  // ============================================================

  // Resume check → Phase 0: Omakase (explore then parallel design exploration)
  Start -> CheckExistingPlans;
  CheckExistingPlans -> PickNextTask [label="resume — plan exists", condition="context.tool_stdout=resume", weight=2];
  CheckExistingPlans -> ArchiveOldPlans [label="fresh start", condition="context.tool_stdout=fresh"];
  ArchiveOldPlans -> ExploreIdea;
  ExploreIdea -> OmakaseFanOut;
  OmakaseFanOut -> DesignExploreOpus;
  OmakaseFanOut -> DesignExploreGPT;
  OmakaseFanOut -> DesignExploreGemini;
  DesignExploreOpus -> OmakaseJoin;
  DesignExploreGPT -> OmakaseJoin;
  DesignExploreGemini -> OmakaseJoin;
  OmakaseJoin -> ConsolidateDesigns;

  // Phase 1: Design Brief (y/n approval gate, freeform feedback on rejection)
  ConsolidateDesigns -> ApproveDesign;
  ApproveDesign -> CommitBrief [label="[Y] Approve", condition="outcome=success", weight=2];
  ApproveDesign -> DesignFeedback [label="[N] Revise", condition="outcome=fail"];
  DesignFeedback -> IncorporateDesignFeedback;
  IncorporateDesignFeedback -> ApproveDesign;

  // Phase 2: Plan (draft-audit-patch loop)
  CommitBrief -> DraftPlan;
  DraftPlan -> ValidatePlanFormat;
  ValidatePlanFormat -> AuditPlanSpec [label="format ok", condition="context.tool_stdout=format_ok", weight=2];
  ValidatePlanFormat -> HumanHelp [label="plan loop exhausted", condition="context.tool_stdout=fail_retries_exhausted"];
  ValidatePlanFormat -> DraftPlan [label="format fail", condition="context.tool_stdout!=format_ok && context.tool_stdout!=fail_retries_exhausted"];
  AuditPlanSpec -> CommitPlan [label="plan approved", condition="outcome=success", weight=2];
  AuditPlanSpec -> PatchPlan [label="gaps found", condition="outcome=fail"];
  PatchPlan -> ValidatePlanFormat;

  // Phase 3: Setup
  CommitPlan -> SetupProject;
  SetupProject -> VerifyBaseline;

  // Phase 4: Cookoff Implement Loop
  VerifyBaseline -> PickNextTask;
  PickNextTask -> CookoffFanOut [label="has task", condition="context.tool_stdout!=all_complete && context.tool_stdout!=no_tasks_found", weight=2];
  PickNextTask -> ValidateBuild [label="all done", condition="context.tool_stdout=all_complete"];
  PickNextTask -> HumanHelp [label="no tasks in plan", condition="context.tool_stdout=no_tasks_found"];
  CookoffFanOut -> ImplementTaskOpus;
  CookoffFanOut -> ImplementTaskGPT;
  CookoffFanOut -> ImplementTaskGemini;
  ImplementTaskOpus -> CookoffJoin;
  ImplementTaskGPT -> CookoffJoin;
  ImplementTaskGemini -> CookoffJoin;
  CookoffJoin -> PickWinner;
  PickWinner -> CheckImplementerReady;
  CheckImplementerReady -> SpecReview [label="ready to review", condition="context.tool_stdout=ready", weight=2];
  CheckImplementerReady -> ImplementerQuestion [label="has question", condition="context.tool_stdout=has_question"];
  ImplementerQuestion -> CookoffFanOut;
  SpecReview -> QualityReview [condition="outcome=success", label="spec pass", weight=2];
  SpecReview -> CheckImplementBudget [condition="outcome=fail", label="spec fail"];
  QualityReview -> MarkTaskComplete [condition="outcome=success", label="quality pass", weight=2];
  QualityReview -> CheckImplementBudget [condition="outcome=fail", label="quality fail"];
  CheckImplementBudget -> CookoffFanOut [label="retry ok", condition="context.tool_stdout=budget_ok", weight=2];
  CheckImplementBudget -> HumanHelp [label="too many attempts", condition="context.tool_stdout=budget_exhausted"];
  MarkTaskComplete -> PickNextTask;

  // Phase 4: Escalation (graduated retry)
  PickWinner -> DebugInvestigate [condition="outcome=fail", label="retries exhausted"];
  DebugInvestigate -> CookoffFanOut [condition="outcome=success", label="fixed, re-verify", weight=2];
  DebugInvestigate -> ReplanTask [condition="outcome=fail", label="can't fix"];
  ReplanTask -> PickNextTask [condition="outcome=success", label="replanned", weight=2];
  ReplanTask -> HumanHelp [condition="outcome=fail", label="stuck"];
  HumanHelp -> ResumeAfterHelp;
  ResumeAfterHelp -> PickNextTask;

  // Phase 5: Final Review
  ValidateBuild -> ReviewFanOut [condition="outcome=success", label="build pass", weight=2];
  ValidateBuild -> CheckReworkBudget [condition="outcome=fail", label="build fail"];

  ReviewFanOut -> FinalReviewOpus;
  ReviewFanOut -> FinalReviewGPT;
  ReviewFanOut -> FinalReviewGemini;
  FinalReviewOpus -> ReviewsJoin;
  FinalReviewGPT -> ReviewsJoin;
  FinalReviewGemini -> ReviewsJoin;

  ReviewsJoin -> CritiqueFanOut;

  CritiqueFanOut -> CritiqueOpusOnGPT;
  CritiqueFanOut -> CritiqueOpusOnGemini;
  CritiqueFanOut -> CritiqueGPTOnOpus;
  CritiqueFanOut -> CritiqueGPTOnGemini;
  CritiqueFanOut -> CritiqueGeminiOnOpus;
  CritiqueFanOut -> CritiqueGeminiOnGPT;
  CritiqueOpusOnGPT -> CritiquesJoin;
  CritiqueOpusOnGemini -> CritiquesJoin;
  CritiqueGPTOnOpus -> CritiquesJoin;
  CritiqueGPTOnGemini -> CritiquesJoin;
  CritiqueGeminiOnOpus -> CritiquesJoin;
  CritiqueGeminiOnGPT -> CritiquesJoin;

  CritiquesJoin -> ReviewConsensus;

  ReviewConsensus -> VerifyTestsFinal [condition="outcome=success", label="pass", weight=2];
  ReviewConsensus -> CheckReworkBudget [condition="outcome=retry", label="rework"];
  ReviewConsensus -> FailureSummary [condition="outcome=fail", label="blocked"];
  CheckReworkBudget -> CookoffFanOut [label="rework ok", condition="context.tool_stdout=budget_ok", weight=2];
  CheckReworkBudget -> FailureSummary [label="rework budget exhausted", condition="context.tool_stdout=budget_exhausted"];
  FailureSummary -> Exit;

  // Phase 6: Finish
  VerifyTestsFinal -> CreatePR [condition="outcome=success", label="tests pass", weight=2];
  VerifyTestsFinal -> CheckReworkBudget [condition="outcome=fail", label="tests fail"];

  CreatePR -> FailureSummary [condition="outcome=fail", label="PR failed"];
  CreatePR -> Exit [condition="outcome=success", label="shipped", weight=2];
}
